# ─── HMS (InstaHMS over Netbird tunnel) ──────────────────────────────────
INSTAHMS_BASE_URL=http://192.168.1.220/instahms
INSTAHMS_HOSPITAL=enjab
INSTAHMS_USER_ID=
INSTAHMS_PASSWORD=

# ─── Postgres ────────────────────────────────────────────────────────────
POSTGRES_USER=enjab
POSTGRES_PASSWORD=
POSTGRES_DB=enjab
DATABASE_URL=postgres://enjab:PASSWORD@localhost:5432/enjab

# ─── Redis ───────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379

# ─── Web app ─────────────────────────────────────────────────────────────
APP_URL=https://automations.enjab.ae
NEXTAUTH_SECRET=                  # 32+ random bytes; will generate in setup
SMTP_URL=                         # for magic-link emails (smtps://user:pass@host:465)
SMTP_FROM="Enjab Automations <noreply@enjab.ae>"

# ─── WhatsApp Cloud API (Meta) ───────────────────────────────────────────
WA_PHONE_NUMBER_ID=
WA_BUSINESS_ACCOUNT_ID=
WA_ACCESS_TOKEN=
WA_APP_ID=
WA_APP_SECRET=
WA_WEBHOOK_VERIFY_TOKEN=
WA_GRAPH_VERSION=v22.0

# ─── Rating automation (will move to DB-backed config later) ─────────────
RATING_GOOGLE_REVIEW_URL=https://g.page/r/CTxj1xpz5jo1EBM/review

# ─── Operational ─────────────────────────────────────────────────────────
TZ=Asia/Dubai
QUIET_HOURS_START=00            # quiet 00:00 — 07:00 Asia/Dubai
QUIET_HOURS_END=07
LOG_LEVEL=info
